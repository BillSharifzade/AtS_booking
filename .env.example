# Copy to .env and fill in real values. Never commit .env.

# Telegram
TELEGRAM_BOT_TOKEN=PUT_YOUR_BOT_TOKEN_HERE
ADMIN_TELEGRAM_IDS=123456789
SAT_BOOKINGS_GROUP_CHAT_ID=-123456789

# Backend
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL_HOURS=12
LOGIN_CODE_TTL_SECONDS=300
# Allowed CORS origins for the admin panel (comma-separated). Set to your prod domain.
# When serving over a LAN/remote host, this must match the origin in the browser's
# address bar, e.g. CORS_ORIGINS=http://192.168.1.156:5173
CORS_ORIGINS=http://localhost:5173

# Database (used by docker-compose)
POSTGRES_DB=ats_booking
POSTGRES_USER=ats
POSTGRES_PASSWORD=ats
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Frontend (Vite reads these at build/dev time). The browser fetches this URL
# directly, so it must be reachable from the user's machine — NOT "localhost"
# when the panel is served remotely. e.g. VITE_API_BASE_URL=http://192.168.1.156:8000
VITE_API_BASE_URL=http://localhost:8000

# Client Telegram Mini Web App (#13). dchr.koinotinav.com is already used by
# another project, so the app lives under the /ats/ subpath of that site (served
# by its existing Nginx — see deploy/nginx-ats.conf). MINIAPP_URL (HTTPS, with
# trailing slash) enables the bot's "open app" menu/inline button — leave it blank
# in local dev. MINIAPP_API_BASE_URL is baked into the build; in production it is
# the same origin under /ats/api so no CORS is needed.
MINIAPP_URL=https://dchr.koinotinav.com/ats/
MINIAPP_API_BASE_URL=https://dchr.koinotinav.com/ats/api

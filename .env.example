# Copy to .env and fill in real values. Never commit .env.

# Telegram
TELEGRAM_BOT_TOKEN=PUT_YOUR_BOT_TOKEN_HERE
ADMIN_TELEGRAM_IDS=123456789
SAT_BOOKINGS_GROUP_CHAT_ID=-123456789

# Backend
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL_HOURS=12
LOGIN_CODE_TTL_SECONDS=300
# Allowed CORS origins for the admin panel (comma-separated). Set to your prod domain.
CORS_ORIGINS=http://localhost:5173

# Database (used by docker-compose)
POSTGRES_DB=ats_booking
POSTGRES_USER=ats
POSTGRES_PASSWORD=ats
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Frontend (Vite reads these at build/dev time)
VITE_API_BASE_URL=http://localhost:8000
